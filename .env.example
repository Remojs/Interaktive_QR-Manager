# Copy this file to .env and fill in your values
# cp .env.example .env

# Port the backend listens on
PORT=3000

# The public base URL of your server (used to build QR redirect URLs)
# For VPS with a domain: BASE_URL=https://qr.yourdomain.com
BASE_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins (no spaces)
# For VPS: ALLOWED_ORIGINS=https://qr.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
